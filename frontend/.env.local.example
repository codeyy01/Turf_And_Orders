# Supabase — from your project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Razorpay — public key only. Secret key stays on your FastAPI backend, never here.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# Your existing FastAPI backend, for dashboard-triggered actions (e.g. manual refund)
NEXT_PUBLIC_API_BASE_URL=https://api.yourplatform.com
